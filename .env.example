# Simkl API credentials
SIMKL_CLIENT_ID=your_simkl_client_id
SIMKL_CLIENT_SECRET=your_simkl_client_secret
SIMKL_ACCESS_TOKEN=

# Simkl anime routing mode (overrides config.yaml providers.simkl.anime_mode)
# Options: auto_native_preferred | tvdb_hybrid_only | native_only
SIMKL_ANIME_MODE=auto_native_preferred

# Import paths (point these at your own export files)
TRAKT_EXPORT_DIR=data/import/trakt
MAL_EXPORT_FILE=data/import/mal_animelist.xml
NUVIO_EXPORT_FILE=data/import/nuvio_collection.json
